// Prisma schema — saas-auth-gateway
//
// Aggregates: tenants + identity + RBAC + API keys + audit trail.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// Tenants
// -----------------------------------------------------------------------------

model Tenant {
  id        String       @id @default(cuid())
  slug      String       @unique
  name      String
  status    TenantStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  users    User[]
  sessions Session[]
  roles    Role[]
  apiKeys  ApiKey[]

  @@map("tenants")
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
}

// -----------------------------------------------------------------------------
// Users, credentials, sessions, refresh tokens
// -----------------------------------------------------------------------------

model User {
  id              String     @id @default(cuid())
  tenantId        String
  email           String
  emailNormalized String
  emailVerifiedAt DateTime?
  displayName     String?
  status          UserStatus @default(ACTIVE)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  credentials Credential[]
  sessions    Session[]
  roles       UserRole[]

  @@unique([tenantId, emailNormalized], name: "tenant_email_unique")
  @@index([tenantId])
  @@map("users")
}

enum UserStatus {
  ACTIVE
  DISABLED
  LOCKED
}

model Credential {
  id        String         @id @default(cuid())
  userId    String
  type      CredentialType
  secret    String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type], name: "user_credential_type_unique")
  @@index([userId])
  @@map("credentials")
}

enum CredentialType {
  PASSWORD
}

model Session {
  id            String    @id @default(cuid())
  userId        String
  tenantId      String
  familyId      String    @default(cuid())
  ip            String?
  userAgent     String?
  createdAt     DateTime  @default(now())
  expiresAt     DateTime
  revokedAt     DateTime?
  revokedReason String?

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]

  @@index([userId, revokedAt])
  @@index([tenantId])
  @@map("sessions")
}

model RefreshToken {
  id            String    @id @default(cuid())
  sessionId     String
  tokenHash     String    @unique
  familyId      String
  issuedAt      DateTime  @default(now())
  expiresAt     DateTime
  rotatedAt     DateTime?
  revokedAt     DateTime?
  revokedReason String?
  replacedById  String?   @unique
  ip            String?
  userAgent     String?

  session      Session       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  replacedBy   RefreshToken? @relation("RefreshTokenChain", fields: [replacedById], references: [id])
  replacedFrom RefreshToken? @relation("RefreshTokenChain")

  @@index([sessionId])
  @@index([familyId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// -----------------------------------------------------------------------------
// RBAC — roles, permissions, assignments
// -----------------------------------------------------------------------------

model Role {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  permissions RolePermission[]
  assignments UserRole[]

  @@unique([tenantId, name], name: "tenant_role_name_unique")
  @@index([tenantId])
  @@map("roles")
}

model RolePermission {
  id         String @id @default(cuid())
  roleId     String
  permission String

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permission], name: "role_permission_unique")
  @@index([roleId])
  @@index([permission])
  @@map("role_permissions")
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  grantedAt DateTime @default(now())
  grantedBy String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId], name: "user_role_unique")
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

// -----------------------------------------------------------------------------
// API keys
// -----------------------------------------------------------------------------

model ApiKey {
  id            String    @id @default(cuid())
  tenantId      String
  name          String
  prefix        String    @unique
  tokenHash     String    @unique
  scopes        String[]
  createdBy     String?
  createdAt     DateTime  @default(now())
  lastUsedAt    DateTime?
  expiresAt     DateTime?
  revokedAt     DateTime?
  revokedReason String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([revokedAt])
  @@map("api_keys")
}

// -----------------------------------------------------------------------------
// Audit log
// -----------------------------------------------------------------------------

model AuditLog {
  id           String   @id @default(cuid())
  tenantId     String?
  actorType    String
  actorId      String?
  action       String
  resourceType String?
  resourceId   String?
  ip           String?
  userAgent    String?
  metadata     Json     @default("{}")
  outcome      String
  createdAt    DateTime @default(now())

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([action])
  @@index([actorId])
  @@index([resourceType, resourceId])
  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}
