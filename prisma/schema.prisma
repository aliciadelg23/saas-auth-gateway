// Prisma schema — saas-auth-gateway
//
// Milestone 2 baseline: identity aggregates required for password-based
// authentication with refresh-token rotation.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  status    TenantStatus @default(ACTIVE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users   User[]
  sessions Session[]

  @@map("tenants")
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
}

model User {
  id             String   @id @default(cuid())
  tenantId       String
  email          String
  emailNormalized String
  emailVerifiedAt DateTime?
  displayName    String?
  status         UserStatus @default(ACTIVE)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  credentials Credential[]
  sessions    Session[]

  @@unique([tenantId, emailNormalized], name: "tenant_email_unique")
  @@index([tenantId])
  @@map("users")
}

enum UserStatus {
  ACTIVE
  DISABLED
  LOCKED
}

model Credential {
  id        String         @id @default(cuid())
  userId    String
  type      CredentialType
  secret    String         // Argon2id hash for PASSWORD
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type], name: "user_credential_type_unique")
  @@index([userId])
  @@map("credentials")
}

enum CredentialType {
  PASSWORD
}

model Session {
  id         String   @id @default(cuid())
  userId     String
  tenantId   String
  familyId   String   @default(cuid())
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())
  expiresAt  DateTime
  revokedAt  DateTime?
  revokedReason String?

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]

  @@index([userId, revokedAt])
  @@index([tenantId])
  @@map("sessions")
}

model RefreshToken {
  id             String   @id @default(cuid())
  sessionId      String
  tokenHash      String   @unique
  familyId       String
  issuedAt       DateTime @default(now())
  expiresAt      DateTime
  rotatedAt      DateTime?
  revokedAt      DateTime?
  revokedReason  String?
  replacedById   String?  @unique
  ip             String?
  userAgent      String?

  session      Session       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  replacedBy   RefreshToken? @relation("RefreshTokenChain", fields: [replacedById], references: [id])
  replacedFrom RefreshToken? @relation("RefreshTokenChain")

  @@index([sessionId])
  @@index([familyId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}
